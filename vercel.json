{
  "version": 2,
  "name": "rinda-initiative",
  "rewrites": [
    { "source": "/rewards", "destination": "/app/rewards.html" },
    { "source": "/clinic", "destination": "/app/clinic.html" },
    { "source": "/admin", "destination": "/app/admin.html" },
    { "source": "/quiz", "destination": "/app/quiz.html" },
    { "source": "/community", "destination": "/app/community.html" },
    { "source": "/library", "destination": "/app/library.html" },
    { "source": "/order", "destination": "/app/order.html" },
    { "source": "/knowledge", "destination": "/app/knowledge.html" },
    { "source": "/menstrual", "destination": "/app/menstrual.html" },
    { "source": "/modules", "destination": "/app/modules.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/js/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/locales/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/css/(.*)\\.css",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
