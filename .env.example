# RINDA Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# In Vercel, add each variable via: Project Settings > Environment Variables
# ─────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/rinda?retryWrites=true&w=majority
MONGODB_URI=

# Admin dashboard password — change this before going live!
ADMIN_SECRET=change-me-before-deploy

# ── OPTIONAL ──────────────────────────────────────────────────────

# Set to 'production' on Vercel, 'development' locally
NODE_ENV=development

# Africa's Talking API (for real USSD/SMS pilot with MTN Rwanda)
# Sign up at: https://africastalking.com
AT_USERNAME=sandbox
AT_API_KEY=
AT_SHORT_CODE=*775#
